# Core service
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
WEB_PORT=5173

# PostgreSQL 17
DATABASE_URL=postgresql://glass_user:replace_me@localhost:5432/glass_claims_db

# Security and tokens
JWT_SECRET=replace_with_high_entropy_value
JOURNEY_TOKEN_TTL_HOURS=24
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW=1 minute

# External services
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=claims@example.com
IMAP_PASSWORD=replace_me
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
WHATSAPP_BUSINESS_TOKEN=replace_me
VIN_DECODER_API_URL=https://example.com/vin
VIN_DECODER_API_KEY=replace_me

# Google Cloud Vision API (OCR VIN Extraction & Damage Analysis)
GOOGLE_CLOUD_VISION_API_KEY=replace_me
GOOGLE_CLOUD_VISION_SERVICE_ACCOUNT=replace_me

# Assessment Configuration
CONFIDENCE_THRESHOLD=0.7
MAX_API_RETRIES=3
RULES_VERSION=1.0.0
RETRY_INITIAL_DELAY_MS=1000
JOURNEY_TOKEN_EXPIRES_HOURS=24
PHOTO_VALIDATION_TIMEOUT_MINUTES=10

# Damage Analysis Configuration
DAMAGE_ANALYSIS_CONFIDENCE_THRESHOLD=0.7
DAMAGE_ANALYSIS_MODEL=gemini-1.5-pro
DAMAGE_ANALYSIS_MAX_RETRIES=3

# Private object storage
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=glass-claim-photos
OBJECT_STORAGE_ACCESS_KEY=replace_me
OBJECT_STORAGE_SECRET_KEY=replace_me
